{
  "manifest_version": 3,
  "name": "Astrodoro",
  "version": "1.0",
  "description": "A space-themed Pomodoro productivity timer.",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "alarms",
    "storage"
  ]
}
